# Embers — environment variables for the Vercel deploy
#
# These are OPTIONAL. The /api/waitlist route has the public anon key + URL
# baked in as defaults so the deploy works without any env vars set.
# Set these only if you rotate keys or want to point preview deploys at a
# different Supabase project.

# Supabase project URL (waitlist DB)
SUPABASE_URL=https://cziyronfdqznnqkpfrlh.supabase.co

# Supabase anon JWT — public, safe to commit. Used by the API route to insert
# into the waitlist table. RLS allows INSERT only — no SELECT/UPDATE/DELETE
# is reachable through this key.
# Fetch from: https://supabase.com/dashboard/project/cziyronfdqznnqkpfrlh/settings/api
SUPABASE_ANON_KEY=
