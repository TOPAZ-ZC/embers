# embers config — this file is generated by install.sh at ~/.embers/config.sh
# you shouldn't need to edit this template — just run install.sh
# but here's what each field does if you want to tweak ~/.embers/config.sh later:

# your first name (goes into the Claude prompt as the "you" voice)
SENDER_NAME="Your Name"

# the other person's first name
RECIPIENT_NAME="Mom"

# how you describe the relationship ("mom", "dad", "sister", "friend", etc)
# Claude uses this to set context
RELATIONSHIP="mom"

# phone number in E.164 format (+1XXXXXXXXXX for US)
RECIPIENT_PHONE="+15555555555"

# how often to check for new messages, in seconds
CHECK_INTERVAL=900

# describe your texting style so Claude can match it
TONE_GUIDANCE="Be warm, casual, short (1-3 sentences). Match their energy. No emojis."

# detected by install.sh — full path to a python3 binary that has Full Disk Access
PYTHON_BIN="/opt/homebrew/bin/python3"

# detected by install.sh — path to the Claude Code CLI
CLAUDE_BIN="/usr/local/bin/claude"
